# SendGrid
SENDGRID_API_KEY=SG....

# OpenAI
OPENAI_API_KEY=sk-...

# Firebase
FIREBASE_CREDENTIALS_JSON={"type": "service_account", ...}

# AWS S3 (for media/static)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=aqar-ai-bucket

# SMS
VONAGE_API_KEY=...
